# infra/app/docker-compose.app.yml ile kullanım: bu dosyayı .env.app olarak kopyalayın.
# Gerçek sırları repoya commit etmeyin.
#
# UYARI — Docker içinde API: DATABASE_URL içinde ASLA "localhost" veya "127.0.0.1" kullanmayın.
# Bunlar container'ın kendisini işaret eder; Postgres host makinedeyse host adı şu olmalı:
#   host.docker.internal  (Docker Desktop Mac/Win; compose'ta extra_hosts tanımlı)
# apps/api/.env'ten kopyaladıysanız localhost satırını mutlaka buna çevirin.

# --- Web imajı build arg (compose --env-file ile okunur) ---
# Tarayıcının göreceği API adresi (host makineden erişim: localhost yeterli)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# İsteğe bağlı port publish
# API_PORT=3001
# WEB_PORT=3000

# --- API container ortamı (.env.app içinde api ile paylaşılır) ---
# Host’taki PostgreSQL (Docker Desktop Mac/Win)
DATABASE_URL=postgresql://KULLANICI:SIFRE@host.docker.internal:5432/VERITABANI

# JWT ve diğer: apps/api/.env.example ile aynı anahtarlar
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Container içinde production: CORS_ORIGIN zorunlu (virgülle ayrılmış tam origin)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

NODE_ENV=production

# İsteğe bağlı — container içinde dosya logu yerine boş bırakılabilir
# API_JSON_LOG_FILE=

# AI / Twilio / Redis vb. gerekiyorsa apps/api/.env ile aynı anahtarları ekleyin
