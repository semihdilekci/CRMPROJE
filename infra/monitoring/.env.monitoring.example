# İzleme stack’i — bu dosyayı `.env.monitoring` olarak kopyalayın (git’e eklenmez).
# cp infra/monitoring/.env.monitoring.example infra/monitoring/.env.monitoring

# --- Grafana metadata PostgreSQL (CRM DB ile aynı instance OLMAMALI — mantıksal ayrım) ---
GRAFANA_DB_USER=grafana
GRAFANA_DB_PASSWORD=grafana_dev_change_me
GRAFANA_DB_NAME=grafana
GRAFANA_DB_PORT=5433

# --- Grafana admin (ilk kurulum) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_dev_change_me
GRAFANA_ROOT_URL=http://localhost:3005

# --- Prometheus (dev ~1 saat; prod için örn. 7d) ---
PROMETHEUS_RETENTION=1h

# --- CRM postgres_exporter → host’taki PostgreSQL (Docker Desktop: host.docker.internal) ---
# Örnek: Prisma DATABASE_URL ile aynı host/port/db; ayrı düşük yetkili kullanıcı önerilir.
POSTGRES_EXPORTER_DSN=postgresql://exporter_readonly:SIFRE@host.docker.internal:5432/VERITABANI_ADI?sslmode=disable

# İsteğe bağlı port override’ları
# GRAFANA_HTTP_PORT=3005
# PROMETHEUS_HTTP_PORT=9090
# LOKI_HTTP_PORT=3100
# BLACKBOX_HTTP_PORT=9115
# POSTGRES_EXPORTER_PORT=9187

# --- Uyarı e-postası alıcısı (provisioning: infra/monitoring/grafana/provisioning/alerting/) ---
CRM_ALERT_EMAIL_TO=you@example.com

# --- SMTP (Grafana Alerting — Mon8-07) ---
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.example.com
# GF_SMTP_USER=
# GF_SMTP_PASSWORD=
# GF_SMTP_FROM_ADDRESS=alerts@example.com
# GF_SMTP_STARTTLS_POLICY=OpportunisticStartTLS
