# API base URL (Expo public — Metro yeniden başlatınca yüklenir)
#
# iOS Simülatör: EXPO_PUBLIC_API_URL tanımlıysa o kullanılır; tanımlı değilse 127.0.0.1 (Mac’teki API).
# Android Emülatör: kod 10.0.2.2 kullanır; burada localhost yazsanız da düzeltilir.
# Fiziksel telefon + Expo Go (aynı Wi‑Fi): bilgisayarınızın LAN IP’si ZORUNLU, örn:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:3001/api/v1
#
# Misafir ağı / AP izolasyonu: telefon API’yi göremez — kişisel hotspot açıp Mac + telefonu aynı
# küçük ağa alın; Mac'in o ağdaki IP'sini kullanın (örn. ipconfig getifaddr en0).
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Faz 7 — TLS public key pinning (üretim, HTTPS API + native development build) ---
# Expo Go’da native modül yok; `npx expo prebuild` / EAS ile derlenmiş uygulama gerekir.
# iOS en az 2 pin ister (birincil + yedek). Hash: openssl ile SPKI SHA-256 base64 — bkz. phase-7 §12.
# EXPO_PUBLIC_ENABLE_SSL_PINNING=true
# EXPO_PUBLIC_SSL_PUBLIC_KEY_HASHES=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=,BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=
