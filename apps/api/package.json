{
  "name": "@crm/api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend API",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migrate:opportunity-products": "ts-node -r tsconfig-paths/register prisma/scripts/migrate-opportunity-products.ts"
  },
  "dependencies": {
    "@crm/shared": "*",
    "@google/genai": "^1.44.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "@types/multer": "^2.1.0",
    "argon2": "^0.44.0",
    "exceljs": "^4.4.0",
    "helmet": "^7.0.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
