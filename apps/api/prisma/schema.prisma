generator client {
  provider      = "prisma-client-js"
  // native: yerel geliştirme. debian-openssl-3.0.x: API Docker (node:20-bookworm-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("user")
  name      String
  phone     String?
  /// Ardışık başarısız parola denemesi (Faz 7 hesap kilidi)
  failedLoginCount Int       @default(0)
  /// Kilitleme bitiş zamanı; null = kilit yok
  lockedUntil      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team?  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  teamId String?

  refreshTokens     RefreshToken[]
  fairs             Fair[]
  stageLogs         OpportunityStageLog[] @relation("StageLogChangedBy")
  opportunityNotes  OpportunityNote[]     @relation("NoteCreatedBy")
}

/// Refresh token rotation: her yenilemede yeni satır; replacedAt ile tek kullanımlık; reuse tespitinde familyId iptali.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  familyId   String
  tokenHash  String    @db.Text
  expiresAt  DateTime
  replacedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@index([active])
}

model Fair {
  id        String   @id @default(cuid())
  name      String
  address   String   @db.Text
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetBudget    String?
  targetTonnage   Float?
  targetLeadCount Int?

  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdById String

  opportunities Opportunity[]

  @@index([createdById])
  @@index([startDate])
}

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  opportunityProducts OpportunityProduct[]
}

model Customer {
  id        String   @id @default(cuid())
  company   String
  name      String
  address   String?  @db.Text
  phone     String?
  email     String?
  cardImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities Opportunity[]
}

model Opportunity {
  id             String   @id @default(cuid())
  budgetRaw      String?
  budgetCurrency String?
  conversionRate String?
  products       String[]
  currentStage   String   @default("tanisma")
  lossReason     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fair       Fair     @relation(fields: [fairId], references: [id], onDelete: Cascade)
  fairId     String

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String

  opportunityProducts OpportunityProduct[]
  stageLogs          OpportunityStageLog[]
  opportunityNotes  OpportunityNote[]
  lastOfferDocument OpportunityOfferDocument?

  @@index([fairId])
  @@index([customerId])
  @@index([conversionRate])
  @@index([currentStage])
}

model OpportunityStageLog {
  id             String   @id @default(cuid())
  stage          String
  note           String?  @db.Text
  lossReason     String?
  createdAt      DateTime @default(now())

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String

  changedBy   User   @relation("StageLogChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  changedById String

  @@index([opportunityId])
  @@index([changedById])
}

model OpportunityProduct {
  id             String   @id @default(cuid())
  quantity       Float?
  unit           String   @default("ton")
  note           String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId String

  @@index([opportunityId])
  @@index([productId])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}

model OpportunityNote {
  id             String   @id @default(cuid())
  opportunityId  String
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdBy    User       @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdById  String

  @@index([opportunityId])
  @@index([createdById])
}

model OpportunityOfferDocument {
  id             String   @id @default(cuid())
  opportunityId  String   @unique
  content        Bytes
  format         String
  createdAt      DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  entityType String   // fair | customer | opportunity | user | product | setting
  entityId   String?
  action     String   // create | update | delete
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
}
