# Backend API — copy to .env and fill. See docs/environment-setup.md
DATABASE_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=
PORT=3001
# Dinleme adresi: mobil/LAN test için 0.0.0.0 (varsayılan). Yalnızca localhost istiyorsanız HOST=127.0.0.1
HOST=0.0.0.0
NODE_ENV=development
# Virgülle ayrılmış tam origin listesi (şema + host + port). Faz 7: credentials ile wildcard yok.
# Production: ZORUNLU. Development: boş bırakılırsa localhost web + Expo varsayılanları kullanılır; LAN IP ile mobil test için ekleyin (örn. http://192.168.1.10:8081).
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
# İsteğe bağlı — httpOnly refresh çerezi (production). Senaryo A: tek host + /api/v1 — COOKIE_DOMAIN genelde boş; PROD'da COOKIE_SAMESITE=strict hedeflenir. Bkz. docs/phase-7-security-hardening.md §2.1
# COOKIE_DOMAIN=
# COOKIE_SECURE=true
# COOKIE_SAMESITE=strict
# Faz 7 sec7-06 — hesap kilidi (uygulandığında). Kesin varsayılanlar: §8 / §13
# ACCOUNT_LOCKOUT_THRESHOLD=5
# ACCOUNT_LOCKOUT_MINUTES=15
REDIS_URL=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# MFA SMS (Twilio Verify) — boş bırakılırsa DEV'de OTP terminale basılır
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
